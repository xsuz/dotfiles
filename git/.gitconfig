[color]
	diff = auto
	status = auto
	branch = auto
	interactive = auto
	grep = auto
	ui = auto
[core]
	editor = nvim
	symlinks = true
	autoCRLF = false
	quotepath = false
	eol = lf
	crlf = false
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
